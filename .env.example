# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  .env.example — Polymarket BTC 15m Assistant                                ║
# ║  Copie este arquivo para .env e preencha os valores.                        ║
# ║  Variaveis marcadas [OBRIGATORIO] devem ser preenchidas.                    ║
# ║  Variaveis marcadas [AUTO] sao geradas pelo keygen.js — nao preencha.       ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# ─── Carteira ─────────────────────────────────────────────────────────────────

# [OBRIGATORIO] Chave privada da carteira MetaMask (EOA/signer).
# Esta e a PK do owner da proxy wallet, NAO da Polymarket diretamente.
# Como obter: MetaMask → 3 pontos → Account details → Show private key.
# Aceita com ou sem prefixo 0x.
PK=

# [OBRIGATORIO] Endereco da proxy wallet (Gnosis Safe) criada pela Polymarket.
# Este endereco e diferente do endereco da MetaMask — os fundos ficam aqui.
# Como obter: polymarket.com → Settings → copie o endereco da carteira.
# Ou no servidor de producao: grep POLYMARKET_PROXY_ADDRESS .env
POLYMARKET_PROXY_ADDRESS=

# [OBRIGATORIO] Tipo de assinatura. Usar 2 (Gnosis Safe) quando proxy esta configurado.
# 0 = EOA direto, 1 = POLY_PROXY, 2 = POLY_GNOSIS_SAFE
POLYMARKET_SIGNATURE_TYPE=2

# ─── API Keys (geradas pelo keygen.js) ────────────────────────────────────────

# [AUTO] Geradas automaticamente por: node keygen.js
# NAO preencha manualmente — o keygen.js grava esses valores apos gerar.
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# ─── Modo de operacao ─────────────────────────────────────────────────────────

# [OPCIONAL] Modo mock — simula ordens sem enviar dinheiro real.
# Padrao: true (seguro). Definir como false para operar com dinheiro real.
TRADE_MOCK_MODE=true

# [OPCIONAL] Slippage tolerado nas ordens (decimal). Padrao: 0.01 (1%)
TRADE_SLIPPAGE=0.01

# [OPCIONAL] Timeframe do bot. Opcoes: btc-15m, btc-5m, eth-15m, eth-5m
# Padrao: btc-15m
TIMEFRAME=btc-15m

# [OPCIONAL] Endereco para saque automatico (Monaco Rule).
# Padrao: endereco hardcoded no executor.
# WITHDRAWAL_ADDRESS=0x...

# ─── Polymarket CLOB ──────────────────────────────────────────────────────────

# [OPCIONAL] Endpoint da API CLOB. Padrao: https://clob.polymarket.com
# POLYMARKET_CLOB_HOST=https://clob.polymarket.com

# [OPCIONAL] Selecao de mercado. Por padrao o bot seleciona automaticamente.
# POLYMARKET_SLUG=                    # fixar um mercado especifico
# POLYMARKET_SERIES_ID=               # ID da serie
# POLYMARKET_SERIES_SLUG=             # slug da serie
# POLYMARKET_AUTO_SELECT_LATEST=true  # selecionar ultimo mercado ativo
# POLYMARKET_LIVE_WS_URL=wss://ws-live-data.polymarket.com
# POLYMARKET_UP_LABEL=Up
# POLYMARKET_DOWN_LABEL=Down

# ─── Blockchain / RPC ────────────────────────────────────────────────────────

# [OPCIONAL] RPC Polygon. Padrao: https://polygon-bor-rpc.publicnode.com
# POLYGON_RPC_URL=https://polygon-bor-rpc.publicnode.com

# [OPCIONAL] RPCs adicionais (fallback), separados por virgula
# POLYGON_RPC_URLS=https://polygon-bor-rpc.publicnode.com,https://rpc.ankr.com/polygon

# [OPCIONAL] WebSocket RPCs para Chainlink
# POLYGON_WSS_URL=
# POLYGON_WSS_URLS=wss://polygon-bor-rpc.publicnode.com

# ─── Chainlink (override, raramente necessario) ──────────────────────────────

# [OPCIONAL] Aggregator address override
# CHAINLINK_BTC_USD_AGGREGATOR=
# CHAINLINK_ETH_USD_AGGREGATOR=

# ─── Binance ─────────────────────────────────────────────────────────────────

# [OPCIONAL] Simbolo do par Binance. Padrao: BTCUSDT (ou ETHUSDT para ETH)
# BINANCE_SYMBOL=BTCUSDT
